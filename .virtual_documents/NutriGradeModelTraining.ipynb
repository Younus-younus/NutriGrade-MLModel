#IQR
data_100grms = ['energy_100g','fat_100g', 'saturated-fat_100g', 'carbohydrates_100g', 
             'sugars_100g', 'proteins_100g', 'salt_100g']

# Keep only rows where all mass columns are <= 100 and >= 0
data = data[(data[data_100grms] <= 100).all(axis=1) & (data[data_100grms] >= 0).all(axis=1)]


